    { "tier": "grammarConcept", "slug": "ser-estar", "name": "ser vs estar", "parent": "es:a1:grammar:verbs:states",
      "pattern": "ser = essence/identity; estar = state/location",
      "explanation": "Both translate as 'to be'; estar covers temporary states (estoy cansado), ser covers identity.",
      "transferTraps": ["Single English 'to be' collapses the distinction"],
      "prerequisites": ["es:a1:grammar:verbs:present-tense"] },

